# ---- Supabase (required) ----
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (keep secret – server-side only, never expose to browser)
# Found at: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Admin ----
ADMIN_PASSCODE=your-strong-admin-passcode

# ---- Email (Resend) - optional for invoice emails ----
# Provider mode: auto | resend | brevo
EMAIL_PROVIDER=resend
# Used only in auto mode, first available provider is selected
EMAIL_PROVIDER_PRIORITY=resend,brevo
# If true, retry with the other provider when fixed provider fails
EMAIL_ALLOW_FAILOVER=false
# Shared sender email used by selected provider
EMAIL_FROM=alerts@afsar.codes
# Admin recipient for new payment request notifications
ADMIN_NOTIFY_EMAIL=liquidlibrary25@gmail.com

# ---- Resend (optional) ----
# Get your API key from https://resend.com/
RESEND_API_KEY=your-resend-api-key
# Must be from a verified Resend domain/sender identity
RESEND_FROM_EMAIL=noreply@mail.yourdomain.com

# ---- Brevo (optional alternative) ----
# Get your API key from https://www.brevo.com/
BREVO_API_KEY=your-brevo-api-key
# Optional fallback sender if EMAIL_FROM is unset
BREVO_FROM_EMAIL=noreply@mail.yourdomain.com

# ---- Local dev override (optional) ----
# Only needed when running `vite dev` standalone (without `vercel dev`).
# VITE_API_BASE_URL=http://localhost:3000
