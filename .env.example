# ---- Supabase (required) ----
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (keep secret – server-side only, never expose to browser)
# Found at: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Admin ----
ADMIN_PASSCODE=7860

# ---- Local dev override (optional) ----
# Only needed when running `vite dev` standalone (without `vercel dev`).
# VITE_API_BASE_URL=http://localhost:3000
