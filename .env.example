# ---- Supabase (required) ----
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (keep secret – server-side only, never expose to browser)
# Found at: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Admin ----
ADMIN_PASSCODE=your-strong-admin-passcode

# ---- Email Configuration ----
# Note: Customer invoices always use Resend, admin notifications always use Brevo
# Shared sender email for both providers (must be verified in respective provider)
EMAIL_FROM=alerts@afsar.codes
# Admin recipient for new payment request notifications (via Brevo)
ADMIN_NOTIFY_EMAIL=admin_mail_id

# ---- Resend (for customer invoices) ----
# Get your API key from https://resend.com/
RESEND_API_KEY=your-resend-api-key
# Verified sender email for Resend (or uses EMAIL_FROM)
RESEND_FROM_EMAIL=noreply@mail.yourdomain.com

# ---- Brevo (for admin notifications) ----
# Get your API key from https://www.brevo.com/
BREVO_API_KEY=your-brevo-api-key
# Verified sender email for Brevo (or uses EMAIL_FROM)
BREVO_FROM_EMAIL=noreply@mail.yourdomain.com

# ---- Local dev override (optional) ----
# Only needed when running `vite dev` standalone (without `vercel dev`).
# VITE_API_BASE_URL=http://localhost:3000
